  m_Script: {fileID: 11500000, guid: 0c26f0ea181b58049b8a6db9d912530d, type: 3}
  m_Name: "Deuxieme entr\xE9e Petits pois"
  m_EditorClassIdentifier: Assembly-CSharp::OpticalFlowTest.PoemAsset
  title: Six boulettes de petits toi
  author: 
  lines:
  - "Fraichement ramass\xE9s ce matin les petits toi"
  - 'Nous les servons en file indienne  '
  - "On dirait une \xE9quipe de bobsleigh "
  - 'Qui prend le chemin de votre bouche '
  - 'Sous leurs pieds ronds : ciboulette fraiche  '
  - 'Ce tapi vert est victorieux  '
  - 'Il trempe dans la stracciatella '
  - 'Terminaison festive, petit toi deviendra '
  - 'Grand nous, capable de tout '
  category: 
