  m_OperatorName: Custom HLSL
  m_HLSLCode: "void ArrowControl(in float2 flow, out float2 multiplier, out float3
    axisY)\n{\n  float l = length(flow);\n  multiplier = float2(l, min(1, l));\n 
    axisY = float3(flow, 0);\n}"
